# Copy this to outreach/.env (which is gitignored) and fill in your values.
# send-emails.js loads it automatically.

GMAIL_USER=chauncey@tsecapital.co
# 16-char Gmail App Password from https://myaccount.google.com/apppasswords
# (spaces are fine; quotes optional)
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Optional:
GMAIL_FROM_NAME=Chauncey Tse
# Where replies go (defaults to GMAIL_USER). Set this if you send from one
# address but want replies elsewhere, e.g. chauncey@signalsnitch.io
GMAIL_REPLY_TO=chauncey@tsecapital.co
# Physical postal address for CAN-SPAM compliance (a PO box is fine)
GMAIL_MAILING_ADDRESS=
